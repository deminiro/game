# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api
API_VERSION=1

# Database (used by Prisma Client at runtime)
DATABASE_URL=postgresql://postgres:postgres@db:5432/game_backend?schema=public
PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1

# Logging
LOG_LEVEL=debug

# Auth (placeholders; fill real values before implementing auth)
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Password hashing (Argon2id; OWASP-recommended defaults)
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Session (Passport + express-session, Postgres-backed)
# SESSION_SECRET: 32+ random bytes (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
SESSION_SECRET=dev-session-secret-change-me-please
SESSION_TTL_MS=604800000

# Cookie config
# Localhost: leave COOKIE_DOMAIN empty, COOKIE_SECURE=false
# Production behind https://api.example.com (frontend on https://example.com): COOKIE_DOMAIN=.example.com COOKIE_SECURE=true
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
